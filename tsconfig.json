{
  "compilerOptions": {
    /* Sprache & Zielumgebung */
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Module */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Ausgabe */
    "outDir": "./dict",
    "rootDir": "./src",
    "sourceMap": true,

    /* Typprüfung */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,

    /* Qualität & Sicherheit */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dict"]
}